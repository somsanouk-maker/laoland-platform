{
  "name": "laoland-backend",
  "version": "0.1.0",
  "description": "LaoLand Platform — Backend API (Showroom + Workshop)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && cp src/db/schema.sql dist/db/schema.sql && cp src/db/seed.sql dist/db/seed.sql && cp -r src/db/migrations dist/db/migrations",
    "start": "node dist/server.js",
    "db:init": "psql \"$DATABASE_URL\" -f src/db/schema.sql && psql \"$DATABASE_URL\" -f src/db/seed.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1078.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "sharp": "^0.33.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "sharp@0.33.5": true
  }
}
