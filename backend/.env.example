# ===== Backend Environment =====
NODE_ENV=development
PORT=4000

# PostgreSQL (ກົງກັບ docker-compose.yml)
DATABASE_URL=postgres://laoland:laoland_dev_pwd@localhost:5432/laoland

# JWT / Session secret
JWT_SECRET=change_me_in_production

# ===== De-duplication thresholds =====
DEDUP_RADIUS_METERS=30          # ລັດສະໝີ GPS ກວດຊໍ້າ (ຕາມຍຸດທະສາດ = 30m)
DEDUP_PHASH_MAX_HAMMING=10      # ໄລຍະ Hamming ≤ ນີ້ = ຮູບຄ້າຍກັນ

# ===== First-Referral Protection =====
REFERRAL_PROTECT_DAYS=90

# ===== WhatsApp Cloud API (Owner Gatekeeping OTP) =====
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ===== Dev OTP bypass — DEV ONLY, MUST be unset in production =====
# When set, ALL logins accept this fixed OTP code (WhatsApp send is skipped).
# For local testing only. Leaving this set in production makes every
# account accessible with this code. Comment it out / remove for prod.
# DEV_OTP=123456

# ===== Currency-Locked Quotes =====
QUOTE_TTL_HOURS=24              # ໄລຍະ lock ລາຄາກ່ອນໝົດອາຍຸ
